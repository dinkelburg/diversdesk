---
import Container from "@components/container.astro";

interface Props {
  title?: string;
  subTitle?: string;
  alt?: string;
}

const { title, subTitle } = Astro.props;

const companylogos = [
  {
    logo: "/images/marquee/Logo_JOM.webp",
    alt: "Jom Adventure Dive, Tioman, Malaysia",
    width: 145,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_BDR.webp",
    alt: "Bali dive Resort and Spa, Bali, Indonesia",
    width: 83,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_SDB.webp",
    alt: "S.E.A. Diving Bali, Bali, Indonesia",
    width: 353,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_Reeflex.webp",
    alt: "Reeflex Dive Resort, Nusa Penida, Indonesia",
    width: 291,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_Purple.webp",
    alt: "Purple Dive, Nusa Penida, Indonesia",
    width: 103,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_Bambu.webp",
    alt: "Bambu Divers, Bali, Indonesia",
    width: 239,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_DI.webp",
    alt: "Diving Indo, Bali, Indonesia",
    width: 151,
    height: 70,
  },
  {
    logo: "/images/marquee/Logo_FM.webp",
    alt: "Fast Manta Diving, Thailand",
    width: 234,
    height: 70,
  },
  {
    logo: "/images/marquee/mts-logo.webp",
    alt: "Logo Mantastic Scuba Paradise, Indonesia",
    width: 80,
    height: 70,
  },
  {
    logo: "/images/marquee/logo-bahura-dive.webp",
    alt: "Logo Bahura Dive, Philippines",
    width: 118,
    height: 70,
  },
  {
    logo: "/images/marquee/tarzan-diving-logo.webp",
    alt: "Logo Tarzan Diving, Indonesia",
    width: 103,
    height: 70,
  },
  {
    logo: "/images/marquee/hgl-tours-logo.webp",
    alt: "Logo Happy Go Lukcie Tours, Belize",
    width: 124,
    height: 70,
  }
];
---

<section class="mx-auto max-w-[1520px] px-4 pt-10 sm:px-12 lg:px-16 lg:pt-10 overflow-x-hidden">
  <div class="mb-6 max-w-full lg:w-4xl">
  <!-- Title -->
  {title && (
    <h2 class="text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-3xl lg:text-4xl">
      {title}
    </h2>
  )}
  {subTitle && (
    <p class="text-lg mt-4 mb-7 text-neutral-600 dark:text-neutral-200">
      {subTitle}
    </p>
  )}
</div>
</section>

  <!-- Logo marquee container -->
  <div class="overflow-x-hidden">
  <div class="-mx-2 sm:-mx-6 lg:-mx-8 pb-20">
    <div class="relative overflow-hidden py-5">
      <div class="relative h-10 md:h-14" data-marquee-viewport>
      <div class="absolute left-0 top-0 w-max shrink-0 flex flex-nowrap items-center gap-16 md:gap-32 will-change-transform" data-marquee-track>
        {companylogos.map((item, index) => (
          <div class="flex justify-center items-center shrink-0 h-10 md:h-14">
            <picture class="block h-full">
              <source srcset={item.logo} type="image/webp" />
              <img class="block h-full w-auto object-contain" src={item.logo} alt={item.alt} loading="lazy" width={item.width} height={item.height} />
            </picture>
          </div>
        ))}
        <div class="shrink-0 w-0" aria-hidden="true"></div>
      </div>
      </div>
    </div>
  </div>
  </div>

  <script src="/scripts/animation.js" is:inline></script>
