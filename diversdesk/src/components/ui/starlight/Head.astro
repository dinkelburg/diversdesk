---
import StarlightHead from "@astrojs/starlight/components/Head.astro";

Astro.props.viewTransitionsFallback = "animate";

const isDocsPage = Astro.url.pathname.startsWith('/user_manual') ||
                   Astro.url.pathname.startsWith('/quickstart_guide') ||
                   Astro.url.pathname.startsWith('/articles') ||
                   Astro.url.pathname.startsWith('/video_training') ||
                   Astro.url.pathname.startsWith('/support') ||
                   Astro.url.pathname.startsWith('/updates') ||
                   Astro.url.pathname.startsWith('/work_in_progress') ||
                   Astro.url.pathname.startsWith('/welcome-to-docs');

const robotsDirective = Astro.url.pathname.startsWith('/support')
  ? 'noindex, nofollow'
  : isDocsPage
  ? 'noindex'
  : null;
---

<StarlightHead {...Astro.props} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
{isDocsPage && <meta name="robots" content={robotsDirective}/>}

<style is:global>
  /* Slow down Chrome's default animation */
  ::view-transition-group(root) {
    animation-duration: 250ms;
  }

  /* Do not slide over the sidebars */
  ::view-transition-group(*) {
    overflow: hidden;
  }
</style>

<script is:inline>
  (() => {
    const topLevelIcons = {
      'Brief Introduction': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 17H20V4H6.5A2.5 2.5 0 0 0 4 6.5v13"/><path d="M8 8h8"/><path d="M8 12h6"/></svg>',
      'Getting Started & Workflows': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="m14.8 9.2-4.6 1.8-1.8 4.6 4.6-1.8 1.8-4.6Z"/></svg>',
      'Activities & Planning': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18"/><path d="M8 14h3"/><path d="M13 14h3"/><path d="M8 18h3"/></svg>',
      'Accommodation': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v7"/><path d="M3 18h18"/><path d="M7 9V7a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v2"/><path d="M7 13h4"/></svg>',
      'Rentals & Retail': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7h12l-1 12H7L6 7Z"/><path d="M9 7a3 3 0 1 1 6 0"/><path d="M10 11h4"/></svg>',
      'Guest Experience': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3.5"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/><path d="M15 3.13a3.5 3.5 0 0 1 0 6.74"/></svg>',
      'Webshop & Online Sales': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/><path d="M3 4h2l2.6 10.4a1 1 0 0 0 1 .76h8.72a1 1 0 0 0 .98-.8L21 7H6"/></svg>',
      'Finance & Data': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19h16"/><path d="M7 15V9"/><path d="M12 15V5"/><path d="M17 15v-3"/></svg>',
      'System & Integrations': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15.5A3.5 3.5 0 1 0 12 8.5a3.5 3.5 0 0 0 0 7Z"/><path d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a1.2 1.2 0 0 1 0 1.7l-1.6 1.6a1.2 1.2 0 0 1-1.7 0l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9v.2A1.2 1.2 0 0 1 13.4 22h-2.8A1.2 1.2 0 0 1 9.4 20.8v-.2a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a1.2 1.2 0 0 1-1.7 0l-1.6-1.6a1.2 1.2 0 0 1 0-1.7l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6h-.2A1.2 1.2 0 0 1 2 13.4v-2.8A1.2 1.2 0 0 1 3.2 9.4h.2a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1L4 7.6a1.2 1.2 0 0 1 0-1.7l1.6-1.6a1.2 1.2 0 0 1 1.7 0l.1.1a1 1 0 0 0 1.1.2 1 1 0 0 0 .6-.9v-.2A1.2 1.2 0 0 1 10.6 2h2.8A1.2 1.2 0 0 1 14.6 3.2v.2a1 1 0 0 0 .6.9 1 1 0 0 0 1.1-.2l.1-.1a1.2 1.2 0 0 1 1.7 0L19.7 5.6a1.2 1.2 0 0 1 0 1.7l-.1.1a1 1 0 0 0-.2 1.1 1 1 0 0 0 .9.6h.2A1.2 1.2 0 0 1 22 10.6v2.8a1.2 1.2 0 0 1-1.2 1.2h-.2a1 1 0 0 0-.9.4Z"/></svg>',
      'Video Tutorials': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m10 9 5 3-5 3Z"/></svg>',
      'Updates': '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 7v6c0 5 3.4 7.6 8 8 4.6-.4 8-3 8-8V7l-8-4Z"/><path d="m9.5 12 1.7 1.7 3.3-3.4"/></svg>'
    };

    const createSidebarIcon = (label) => {
      const markup = topLevelIcons[label];

      if (!markup) {
        return null;
      }

      const icon = document.createElement('span');
      icon.className = 'sidebar-category-icon';
      icon.setAttribute('aria-hidden', 'true');
      icon.innerHTML = markup;
      return icon;
    };

    const initializeSidebarEnhancements = () => {
      const topLevelLinks = Array.from(
        document.querySelectorAll('#starlight__sidebar ul.top-level > li > a.large')
      );

      topLevelLinks.forEach((link) => {
        if (link.querySelector('.sidebar-category-icon')) {
          return;
        }

        const labelNode = link.querySelector('span');
        const label = labelNode?.textContent?.trim();
        const icon = label ? createSidebarIcon(label) : null;

        if (!icon) {
          return;
        }

        link.classList.add('top-level-link-card');
        link.prepend(icon);
      });

      const topLevelSummaries = Array.from(
        document.querySelectorAll('#starlight__sidebar ul.top-level > li > details > summary')
      );

      topLevelSummaries.forEach((summary) => {
        if (summary.querySelector('.sidebar-category-icon')) {
          return;
        }

        const groupLabel = summary.querySelector('.group-label');
        const labelNode = groupLabel?.querySelector('.large');
        const label = labelNode?.textContent?.trim();
        const icon = label ? createSidebarIcon(label) : null;

        if (!icon || !groupLabel) {
          return;
        }

        summary.classList.add('top-level-summary-card');
        groupLabel.prepend(icon);
      });

      const topLevelGroups = Array.from(
        document.querySelectorAll('#starlight__sidebar .sidebar-content > sl-sidebar-state-persist > ul.top-level > li > details')
      );

      if (topLevelGroups.length === 0) {
        return;
      }

      const syncSidebarState = () => {
        try {
          const persistRoot = document.querySelector('sl-sidebar-state-persist');
          const hash = persistRoot?.getAttribute('data-hash');

          if (!hash) {
            return;
          }

          const allDetails = Array.from(document.querySelectorAll('#starlight__sidebar details'));
          const open = allDetails.map((details) => details.open);
          const scroller = document.getElementById('starlight__sidebar');

          sessionStorage.setItem(
            'sl-sidebar-state',
            JSON.stringify({
              hash,
              open,
              scroll: scroller?.scrollTop ?? 0,
            })
          );
        } catch {}
      };

      const closeAllTopLevelGroups = () => {
        topLevelGroups.forEach((group) => {
          group.open = false;
        });

        syncSidebarState();
      };

      topLevelLinks.forEach((link) => {
        if (link.dataset.closeGroupsBound === 'true') {
          return;
        }

        link.dataset.closeGroupsBound = 'true';
        link.addEventListener('click', () => {
          closeAllTopLevelGroups();
        });
      });

      if (topLevelLinks.some((link) => link.getAttribute('aria-current') === 'page')) {
        closeAllTopLevelGroups();
      }

      topLevelGroups.forEach((group) => {
        if (group.dataset.accordionBound === 'true') {
          return;
        }

        group.dataset.accordionBound = 'true';
        group.addEventListener('toggle', () => {
          if (!group.open) {
            syncSidebarState();
            return;
          }

          topLevelGroups.forEach((otherGroup) => {
            if (otherGroup !== group) {
              otherGroup.open = false;
            }
          });

          syncSidebarState();
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeSidebarEnhancements, { once: true });
    } else {
      initializeSidebarEnhancements();
    }

    document.addEventListener('astro:after-swap', initializeSidebarEnhancements);
    document.addEventListener('astro:page-load', initializeSidebarEnhancements);
  })();
</script>
