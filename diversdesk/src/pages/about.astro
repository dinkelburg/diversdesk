---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import NormalContent from "@components/ui/blocks/NormalContent.astro";
import CoFounderSection from "@components/ui/blocks/CoFounderSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import MacBookAir from "@images/MacBookAir.png";
import MedicalFormPhone from "@images/medical_signature.png";
import RegisrationPagePhone from "@images/registration_page_med_required.png";
import CustomWaivers from "@images/custom_waivers_2.png";
import StaffCalIpad from "@images/staff_calendar_ipad.png";
import DataBase3 from "@images/customer_database3.png";
import TestimonialsSectionAlt from "@components/sections/testimonials/TestimonialsSectionAlt.astro";

// Import necessary images
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  content: string; // HTML string
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}



const pageTitle: string = "About DiversDesk | Dive Center Software Team & Mission";
---

<MainLayout
  title={pageTitle}
  description="Discover DiversDesk's story: who we are, why we built the leading dive center management software, and our mission to make dive shop operations effortless worldwide."
  image="/images/hero-image.png"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://www.diversdesk.com/about",
    "url": "https://www.diversdesk.com/about",
    "name": "About DiversDesk: Transforming Dive Center Management",
    "description": "Dive Center Management Software for Streamlined Operations, Enhanced Customer Experiences, and Seamless Bookkeeping Integration. Learn about our mission, vision, and global impact on the diving industry.",
    "isPartOf": {
        "@type": "WebSite",
        "url": "https://www.diversdesk.com",
        "name": "Diversdesk",
        "description": "Comprehensive Dive Center Management Software with Booking, Scheduling, Waivers, and Seamless Integration. Enhance Your Dive Operations Worldwide."
    },
    "founders": [
      {
        "@type": "Person",
        "name": "Bart",
        "jobTitle": "Co-Founder & CEO",
        "image": "https://www.diversdesk.com/emailsignature/Bart.png"
      },
      {
        "@type": "Person",
        "name": "Ruben",
        "jobTitle": "Co-Founder & CTO",
        "image": "https://www.diversdesk.com/emailsignature/Ruben1.png"
      }
    ],
    "inLanguage": "en-US"
  }}
  showBanner={false}
  >

  <NormalContent
  title="From Passion to Solution: The Diversdesk Story"
  chapters={[
    {
      content: "Diversdesk originated as a passion project during the COVID pandemic, fueled by our deep love for diving and a strong awareness of the daily challenges faced by dive centers. As we built close relationships within the industry, we were frequently asked if we could develop a solution to streamline dive center operations. Leveraging the robust foundation of our marketplace backend, we recognized the opportunity to create a comprehensive Dive Center Management system."
    },
    {
      content: "Collaborating directly with dive centers in Indonesia—particularly in the most tourism-driven and dynamic diving locations—we tailored our solution to meet the specific needs of the industry. Our first milestone was the development of an efficient planner, scheduling, and booking system. From there, we streamlined the digital onboarding process, enabling dive centers to onboard customers paperlessly."
    },
    {
      content: "Today, Diversdesk is active in five countries, with customers worldwide. We’re incredibly grateful to be able to work full-time on our passion, continuously developing new features. Recent innovations include a seamless bookkeeping integration and the ability to accept direct bookings through our customers' websites. And we're just getting started—our development is an ongoing process, and we invite you to subscribe to our newsletter to stay updated on what's next."
    },
    {
      title: "Vision Statement",
      content: "At Diversdesk, our vision is to revolutionize dive center management by providing innovative, user-friendly solutions that empower centers to focus on creating memorable experiences for their customers. We believe in a world where technology simplifies operations, reduces environmental impact, and enhances every diver’s journey. Through continuous development and close collaboration with our users, we aim to set the standard for dive center management worldwide, ensuring that diving is always about the adventure, not the paperwork."
    }
  ]}
  />

  <!-- MainSection is the introductory section of the page, it also contains a CTA button-->
  <CoFounderSection
  mainTitle="A Word From the Founders"
  leftTitle="Bart"
  leftSubtitle="Co-Founder & CEO"
  leftContent="As a devoted diver with over 12 years of experience as a project manager and business owner in the tech industry, I co-founded Diversdesk after witnessing firsthand the challenges dive centers face. Growing up in an entrepreneurial family, business and customer service are second nature to me. My goal? To create intuitive solutions that address these challenges head-on. I’m passionate about making diving and dive center management as seamless as possible, ensuring that every dive is about the adventure, not the paperwork. Whether it's streamlining operations or simplifying customer onboarding, I want to empower dive centers to focus on what they do best—delivering unforgettable experiences."
  leftImage="/emailsignature/Bart.png"
  rightTitle="Ruben"
  rightSubtitle="Co-Founder & CTO"
  rightContent="I co-founded Diversdesk driven by curiosity and a passion for problem-solving. With 10 years of experience as a developer, I've had the privilege to work on various state-of-the-art projects and become an expert in database management. As I grew into a passionate diver, I aimed to innovate and enhance dive center operations. My goal is to make every center and diver’s experience smoother and more enjoyable. By focusing on user-friendly solutions and continuous innovation, I strive to transform how dive centers operate, ensuring a more seamless process for everyone involved."
  rightImage="/emailsignature/Ruben1.png"
  />

  
  <!-- RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  -->

  <!--FeaturesStats section showcases essential stats valuable to users-->
  <!-- <FeaturesStats
    title="By the Numbers"
    subTitle="Our commitment to quality and reliability is evident in every project we undertake. At Diversdesk, we are dedicated to delivering industry-leading services that ensure your construction projects are built to last."
    mainStatTitle="96%"
    mainStatSubTitle="of our clients rate their experience with Diversdesk as exceptional"
    stats={[
