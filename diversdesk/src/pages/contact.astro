---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/ContactSection.astro";
import { SITE } from "@data/constants";

const pageTitle: string = "Contact DiversDesk | Dive Center Software Support";
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title={pageTitle}
  description="Reach out to our team to discuss your dive center needs and explore tailored solutions."
  image="/images/contact-hero.avif"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://www.diversdesk.com/contact",
    "url": "https://www.diversdesk.com/contact",
    "name": "Contact Us | Diversdesk",
    "description":
      "Have Questions or Need Assistance? Reach Out to Our Team to Discuss Your Dive Center Needs and Explore Tailored Solutions. Let's Work Together to Optimize Your Operations.",
    "isPartOf": {
      "@type": "WebSite",
      "url": "https://www.diversdesk.com",
      "name": "Diversdesk",
      "description":
        "Comprehensive Dive Center Management Software with Booking, Scheduling, Waivers, and Seamless Integration. Enhance Your Dive Operations Worldwide.",
    },
    "inLanguage": "en-US"
  }}
  showBanner={false}
>

  <!-- Hero image fallbacks -->
  <noscript>
    <picture>
      <source srcset="/images/contact-hero.avif" type="image/avif" />
      <source srcset="/images/contact-hero.webp" type="image/webp" />
      <img src="/images/contact-hero.png" alt="A customer digitally onboarding using a mobile phone, showcasing DiversDesk's expert dive center solutions." />
    </picture>
  </noscript>

  <ContactSection />
</MainLayout>
