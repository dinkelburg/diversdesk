---
import MainLayout from "@/layouts/MainLayout.astro";

const activityBookingUrl =
  "https://example.diversdesk.com/establishment/d06901a7-439d-49d9-827f-84b9004527b5/shop/activity/37d16da1-33a6-4a36-80dc-27287421d755?persist_flow=signin&persist_authMethod=password";
---

<MainLayout
  title="Diversdesk Iframe Test - Specific Activity"
  description="Test page for embedding a specific Diversdesk activity booking URL."
  robots="noindex, nofollow"
>
  <section class="mx-auto w-full max-w-[1500px] px-4 py-8 sm:px-6 lg:px-8">
    <h1 class="text-2xl font-bold text-neutral-800 dark:text-white">Specific Activity Embed Test</h1>
    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">
      Use this page to test deep-linking directly to one activity booking flow.
    </p>

    <div class="mt-4 flex flex-wrap items-center gap-2 rounded-lg border border-neutral-200 bg-neutral-50/70 p-2 text-xs dark:border-neutral-700 dark:bg-neutral-900/40">
      <a
        href="/iframe-test"
        class="rounded-md border border-neutral-200 bg-white px-3 py-1.5 font-normal text-neutral-600 hover:border-neutral-300 hover:bg-neutral-100 hover:text-neutral-800 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300 dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
      >
        Side Panel Example
      </a>
      <a
        href="/iframe-test-general"
        class="rounded-md border border-neutral-200 bg-white px-3 py-1.5 font-normal text-neutral-600 hover:border-neutral-300 hover:bg-neutral-100 hover:text-neutral-800 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300 dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
      >
        General Webshop Example
      </a>
      <a
        href="/iframe-test-activity"
        class="rounded-md border border-orange-300 bg-orange-50 px-3 py-1.5 font-medium text-orange-700 hover:bg-orange-100 dark:border-orange-700 dark:bg-orange-950 dark:text-orange-200 dark:hover:bg-orange-900"
      >
        Specific Activity Example
      </a>
    </div>

    <div class="mt-6 overflow-hidden rounded-xl border border-neutral-200 shadow-sm dark:border-neutral-700">
      <iframe
        src={activityBookingUrl}
        title="Diversdesk Specific Activity Test"
        class="block h-[1800px] w-full border-0 lg:h-[2200px]"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
      ></iframe>
    </div>
  </section>
</MainLayout>
