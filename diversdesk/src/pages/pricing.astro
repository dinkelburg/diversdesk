---
import MainLayout from "@/layouts/MainLayout.astro";
import SoftwareApplicationSchema from "@components/sections/seo-specific/SoftwareApplicationSchema.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import ComparePricing from "@components/compare-pricing.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import pricing from "@data/pricing.json";
---


<MainLayout
    title="Pricing Plans | DiversDesk"
  description="Explore DiversDesk's affordable pricing plans for dive center management software. Choose the plan that fits your needs and streamline your operations today!"
  image="/images/Laptop-and-phone-diversdesk.avif"
    structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://www.diversdesk.com/pricing",
    "url": "https://www.diversdesk.com/pricing",
    "name": "Pricing Plans | DiversDesk",
    "description": "Explore DiversDesk's affordable pricing plans for dive center management software. Choose the plan that fits your needs and streamline your operations today.",
    "isPartOf": {
      "@type": "WebSite",
      "url": "https://www.diversdesk.com",
      "name": "DiversDesk",
      "description": "Comprehensive Dive Center Management Software with Booking, Scheduling, Waivers, and Seamless Integration. Enhance Your Dive Operations Worldwide."
    },
    "inLanguage": "en-US"
  }}
  showBanner={false}>

  <!-- Hero image fallback -->
  <noscript>
    <picture>
      <source srcset="/images/Laptop-and-phone-diversdesk.avif" type="image/avif" />
      <source srcset="/images/Laptop-and-phone-diversdesk.webp" type="image/webp" />
      <img src="/images/Laptop-and-phone-diversdesk.png" alt="A laptop and phone displaying DiversDesk dive center management software, showcasing scheduling and booking features." />
    </picture>
  </noscript>

    <Container >
        <!--<Sectionhead/>-->
        <PricingSection pricing={pricing}/>
        <ComparePricing/>
    </Container>

    <SoftwareApplicationSchema/>

</MainLayout>
